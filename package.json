{
  "name": "shiprank",
  "private": true,
  "version": "0.1.0",
  "packageManager": "bun@1.3.14",
  "type": "module",
  "engines": {
    "node": ">=22.19.0"
  },
  "scripts": {
    "lint": "eslint .",
    "dev": "vite",
    "dev:full": "bun run build && wrangler pages dev dist --local",
    "build": "tsc -b && vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "capture:taste": "node scripts/capture-taste.mjs",
    "capture:taste:install": "playwright install chromium",
    "validate:taste-capture-queue": "bun scripts/validate-taste-capture-queue.ts",
    "queue:taste-captures": "bun scripts/run-taste-capture-queue.ts",
    "pair:taste": "node scripts/create-taste-pair.mjs",
    "synth:taste-degrade": "bun scripts/synthesize-taste-degradations.ts",
    "baseline:taste": "bun scripts/evaluate-taste-pair.ts",
    "evidence:taste": "bun scripts/upload-taste-evidence.ts",
    "capture-study:taste": "bun scripts/request-taste-capture.ts",
    "audit:taste-pairs": "bun scripts/audit-taste-pairs.ts",
    "export:taste-jsonl": "bun scripts/export-taste-jsonl.ts",
    "audit:taste-jsonl": "bun scripts/audit-taste-jsonl.ts",
    "review:taste-pairs": "bun scripts/review-taste-pairs.ts",
    "label:taste-pair": "bun scripts/label-taste-pair.ts",
    "split:taste-jsonl": "bun scripts/split-taste-jsonl.ts",
    "eval:taste-jsonl": "bun scripts/evaluate-taste-jsonl.ts",
    "train:taste-ranker": "bun scripts/train-taste-ranker.ts",
    "report:taste-model": "bun scripts/report-taste-model.ts",
    "experiment:taste-screenshot-ranker": "bun scripts/experiment-taste-screenshot-ranker.ts",
    "smoke:taste-ranker": "bun scripts/smoke-taste-ranker-runtime.ts",
    "capture-worker:check": "tsc -p workers/taste-capture/tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply shiprank-db --local",
    "db:seed": "node scripts/seed.mjs",
    "deploy": "bun run build && wrangler pages deploy dist --project-name=shiprank"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.100.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.11.4",
    "lucide-react": "^1.11.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "globals": "^15.0.0",
    "typescript-eslint": "^8.0.0",
    "@cloudflare/puppeteer": "^1.1.0",
    "@cloudflare/workers-types": "^4.20260311.0",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "drizzle-kit": "^0.31.10",
    "playwright": "^1.61.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "wrangler": "^4.85.0"
  }
}
